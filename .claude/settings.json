{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hermes-safety-adapter.sh"
          }
        ]
      }
    ]
  }
}
